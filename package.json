    "seo:priority": "node scripts/build-seo-system.js",
    "seo:og": "node scripts/apply-og-fallbacks.js",
    "seo:links": "node scripts/fix-seo-alias-links.js",
    "seo:canon-links": "node scripts/fix-canonical-alias-links.js",
    "seo:redirects": "node scripts/update-html-canonical-redirects.js",
