{
  "name": "afrotools",
  "version": "1.0.0",
  "description": "",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "minify": "node scripts/minify.js",
    "sitemap": "node scripts/generate-sitemaps.js",
    "check-links": "node scripts/check-links.js",
    "audit": "node scripts/audit-tools.js",
    "bundle": "node scripts/bundle.js && node scripts/update-html-bundles.js",
    "build": "node scripts/minify.js && node scripts/bundle.js && node scripts/update-html-bundles.js && node scripts/build-related-tools-data.js && node scripts/prune-unused-registry.js && node scripts/build-seo-system.js && node scripts/apply-og-fallbacks.js && node scripts/cachebust.js && node scripts/inject-internal-links.js && node scripts/generate-sitemaps.js && node scripts/stamp-sw.js",
    "test:car-import-cost": "node tests/car-import-cost-rule-packs.test.js && node tests/car-import-cost-engine.test.js && node tests/car-import-cost-routes.test.js",
    "test:car-price-intelligence": "node tests/car-price-intelligence.test.js && node tests/cars-routes.test.js",
    "build:i18n": "node scripts/build-i18n.js --all",
    "build:i18n:fr": "node scripts/build-i18n.js --lang fr",
    "build:i18n:validate": "node scripts/build-i18n.js --validate",
    "build:i18n:dry-run": "node scripts/build-i18n.js --dry-run",
    "validate:hreflang": "node scripts/validate-hreflang.js",
    "build:i18n:full": "npm run build:i18n -- --all && npm run validate:hreflang",
    "test": "node scripts/check-links.js && node scripts/audit-tools.js",
    "seo": "node scripts/seo-daily-fix.js",
    "seo:priority": "node scripts/build-seo-system.js",
    "seo:og": "node scripts/apply-og-fallbacks.js",
    "seo:links": "node scripts/fix-seo-alias-links.js",
    "seo:dry": "node scripts/seo-daily-fix.js --dry-run",
    "seo:report": "node scripts/seo-daily-fix.js --report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ozaveshe/afrotools.git"
  },
  "keywords": [],
  "author": "",
