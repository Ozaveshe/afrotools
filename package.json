    "cars:research:queue:wave3": "node scripts/generate-real-data-research-queue.js --wave data/cars/catalog-expansion-wave-3-premium-ev.csv --output data/cars/real-data-research-queue-wave-3-premium-ev.csv --wave-only",
    "bundle": "node scripts/bundle.js && node scripts/update-html-bundles.js",
    "build": "node scripts/update-counts.js --write && node scripts/minify.js && node scripts/bundle.js && node scripts/update-html-bundles.js && node scripts/build-related-tools-data.js && node scripts/prune-unused-registry.js && node scripts/build-seo-system.js && node scripts/apply-og-fallbacks.js && node scripts/cachebust.js && node scripts/inject-internal-links.js && node scripts/fix-canonical-alias-links.js && node scripts/update-html-canonical-redirects.js && node scripts/generate-sitemaps.js && node scripts/seo-daily-fix.js && node scripts/stamp-sw.js",
