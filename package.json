  },
  "homepage": "https://github.com/Ozaveshe/afrotools#readme",
  "dependencies": {
    "@netlify/blobs": "^10.7.2",
    "@supabase/supabase-js": "^2.99.2",
    "docx": "^9.6.1"
  },
  "devDependencies": {
