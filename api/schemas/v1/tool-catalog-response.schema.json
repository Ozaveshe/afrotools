{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/api/schemas/v1/tool-catalog-response.schema.json",
  "title": "AfroTools SalaryPadi tool catalog response v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "product", "category", "publishedAt", "lastVerified", "count", "tools", "supportingApis", "contract"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "product": { "const": "salarypadi" },
    "category": { "const": "career" },
    "publishedAt": { "type": "string", "format": "date" },
    "lastVerified": { "type": "string", "format": "date" },
    "count": { "type": "integer", "minimum": 1 },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tool" }
    },
    "supportingApis": { "type": "array", "items": { "$ref": "#/$defs/apiReference" } },
    "contract": {
      "type": "object",
      "required": ["schema", "documentation", "attribution"],
      "properties": {
        "schema": { "type": "string", "format": "uri" },
        "documentation": { "type": "string", "format": "uri" },
        "attribution": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "apiReference": {
      "type": "object",
      "required": ["id", "method", "path", "inputSchema", "outputSchema", "lastVerified"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "method": { "enum": ["GET", "POST"] },
        "path": { "type": "string", "pattern": "^/api/v1/" },
        "inputSchema": { "type": "string", "format": "uri" },
        "outputSchema": { "type": "string", "format": "uri" },
        "lastVerified": { "type": "string", "format": "date" }
      }
    },
    "tool": {
      "type": "object",
      "required": ["schemaVersion", "id", "name", "description", "category", "integrationMode", "canonicalUrl", "countries", "api", "widget", "inputSchema", "outputSchema", "rulesVersion", "lastVerified", "disclaimer", "attribution"],
      "properties": {
        "schemaVersion": { "const": "1.0.0" },
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "category": { "const": "career" },
        "integrationMode": { "enum": ["api", "widget", "link"] },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "countries": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^(ALL|[A-Z]{2})$" } },
        "api": { "anyOf": [{ "$ref": "#/$defs/toolApi" }, { "type": "null" }] },
        "widget": { "anyOf": [{ "type": "object" }, { "type": "null" }] },
        "inputSchema": { "type": ["string", "null"], "format": "uri" },
        "outputSchema": { "type": ["string", "null"], "format": "uri" },
        "rulesVersion": { "type": ["string", "null"] },
        "lastVerified": { "type": "string", "format": "date" },
        "disclaimer": { "type": "string", "minLength": 1 },
        "attribution": {
          "type": "object",
          "required": ["required", "text", "url"],
          "properties": {
            "required": { "const": true },
            "text": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    },
    "toolApi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path"],
      "properties": {
        "method": { "enum": ["GET", "POST"] },
        "path": { "type": "string", "pattern": "^/api/v1/" }
      }
    }
  }
}
