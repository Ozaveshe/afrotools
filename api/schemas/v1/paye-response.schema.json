{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/api/schemas/v1/paye-response.schema.json",
  "title": "AfroTools PAYE response v1",
  "type": "object",
  "required": ["status", "input", "deductions", "tax", "result", "_meta"],
  "properties": {
    "status": { "const": "success" },
    "input": { "type": "object" },
    "deductions": { "type": "object" },
    "tax": {
      "type": "object",
      "required": ["bands"],
      "properties": {
        "bands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "rate", "amount"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "amount": { "type": "number", "minimum": 0 },
              "from": { "type": "number", "minimum": 0 },
              "to": { "type": "number", "minimum": 0 },
              "taxInBand": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "result": { "type": "object" },
    "_meta": {
      "type": "object",
      "required": ["api", "version", "timestamp", "sandbox", "dataPolicy", "docs"],
      "properties": {
        "api": { "const": "AfroTax" },
        "version": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "sandbox": { "type": "boolean" },
        "dataPolicy": { "type": "string", "minLength": 1, "maxLength": 160 },
        "docs": { "type": "string", "format": "uri" }
      }
    }
  }
}
