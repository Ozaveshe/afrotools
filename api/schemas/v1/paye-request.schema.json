{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/api/schemas/v1/paye-request.schema.json",
  "title": "AfroTools PAYE request v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["country"],
  "properties": {
    "country": { "const": "NG" },
    "grossAnnual": { "type": "number", "exclusiveMinimum": 0 },
    "grossMonthly": { "type": "number", "exclusiveMinimum": 0 },
    "netAnnual": { "type": "number", "exclusiveMinimum": 0 },
    "netMonthly": { "type": "number", "exclusiveMinimum": 0 }
  },
  "oneOf": [
    { "required": ["grossAnnual"] },
    { "required": ["grossMonthly"] },
    { "required": ["netAnnual"] },
    { "required": ["netMonthly"] }
  ]
}
