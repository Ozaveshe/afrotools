# SEO — prevent trailing-slash 301 redirects (catches all directory index pages)
# These catch-all rules MUST stay at the bottom. Netlify uses first-match-wins,
# so all specific rules above take priority. These only fire for paths not
# already handled above, eliminating the /path → /path/ 301 redirect that
# Google Search Console flags as "Page with redirect".

# Tool pages: /tools/xyz → /tools/xyz/index.html (200, no redirect)
/tools/:tool          /tools/:tool/index.html          200

# Country & top-level pages: /xyz → /xyz/index.html (200, no redirect)
/:page                /:page/index.html                200
