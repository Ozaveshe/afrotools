{
  "id": "ng-paye-2026",
  "tool": "Nigeria PAYE Calculator 2026",
  "dataSource": "FIRS / NTA 2025",
  "lastVerified": "2026-03-26",
  "tolerance": 0.01,
  "notes": "NTA 2025 bands: 0% on first 800K, then 15/18/21/23/25%. Pension 8% on Basic+Housing+Transport. NHF 2.5% on Basic. CRA = max(1% gross, 200K) + 20% gross.",
  "bands": {
    "year": 2026,
    "regime": "NTA 2025",
    "brackets": [
      { "from": 0, "to": 800000, "rate": 0 },
      { "from": 800001, "to": 1100000, "rate": 0.15 },
      { "from": 1100001, "to": 1600000, "rate": 0.18 },
      { "from": 1600001, "to": 3200000, "rate": 0.21 },
      { "from": 3200001, "to": 5200000, "rate": 0.23 },
      { "from": 5200001, "to": null, "rate": 0.25 }
    ],
    "pension": { "rate": 0.08, "appliesTo": ["basic", "housing", "transport"] },
    "nhf": { "rate": 0.025, "appliesTo": ["basic"] },
    "cra": "max(0.01 * grossIncome, 200000) + 0.20 * grossIncome"
  },
  "testCases": [
    {
      "name": "basic-500k-annual",
      "description": "Annual gross salary of 500,000 NGN — should fall entirely in 0% band after CRA",
      "inputs": {
        "#salary-input": "500000",
        "#period-select": "annual"
      },
      "expectedOutputs": {
        ".take-home-value": "390000",
        ".tax-amount": "0",
        ".pension-amount": "40000",
        ".nhf-amount": "12500"
      }
    },
    {
      "name": "mid-range-3m-annual",
      "description": "Annual gross of 3,000,000 NGN — spans multiple tax bands",
      "inputs": {
        "#salary-input": "3000000",
        "#period-select": "annual"
      },
      "expectedOutputs": {
        ".tax-amount": "163500"
      }
    },
    {
      "name": "high-earner-10m-annual",
      "description": "Annual gross of 10,000,000 NGN — top band territory",
      "inputs": {
        "#salary-input": "10000000",
        "#period-select": "annual"
      },
      "expectedOutputs": {
        ".tax-amount": "1123500"
      }
    },
    {
      "name": "monthly-250k",
      "description": "Monthly salary of 250,000 NGN",
      "inputs": {
        "#salary-input": "250000",
        "#period-select": "monthly"
      },
      "expectedOutputs": {
        ".monthly-take-home": "201375"
      }
    },
    {
      "name": "edge-zero",
      "description": "Zero salary — should show zero tax, zero deductions",
      "inputs": {
        "#salary-input": "0"
      },
      "expectedOutputs": {
        ".tax-amount": "0",
        ".take-home-value": "0"
      }
    }
  ]
}
