{
  "id": "ng-vat-2026",
  "tool": "Nigeria VAT Calculator 2026",
  "dataSource": "FIRS / VATA 2021",
  "lastVerified": "2026-03-26",
  "tolerance": 0.001,
  "rates": {
    "standard": 0.075,
    "zeroRated": 0,
    "zeroRatedItems": ["unprocessed food (from Jan 2026)"],
    "exempt": ["healthcare", "education", "domestic transport", "financial services", "agricultural inputs"]
  },
  "testCases": [
    {
      "name": "add-vat-standard",
      "description": "Add 7.5% VAT to 100,000 NGN",
      "inputs": {
        "#amount-input": "100000"
      },
      "expectedOutputs": {
        ".vat-amount": "7500",
        ".total-inclusive": "107500"
      }
    },
    {
      "name": "remove-vat-standard",
      "description": "Remove 7.5% VAT from 107,500 NGN",
      "inputs": {
        "#amount-input": "107500"
      },
      "expectedOutputs": {
        ".pre-tax-amount": "100000",
        ".vat-amount": "7500"
      }
    },
    {
      "name": "large-amount",
      "description": "Add VAT to 50,000,000 NGN",
      "inputs": {
        "#amount-input": "50000000"
      },
      "expectedOutputs": {
        ".vat-amount": "3750000",
        ".total-inclusive": "53750000"
      }
    },
    {
      "name": "small-amount",
      "description": "Add VAT to 100 NGN",
      "inputs": {
        "#amount-input": "100"
      },
      "expectedOutputs": {
        ".vat-amount": "7.50",
        ".total-inclusive": "107.50"
      }
    }
  ]
}
