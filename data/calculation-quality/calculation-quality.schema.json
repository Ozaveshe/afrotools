{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/schemas/calculation-quality.schema.json",
  "title": "AfroTools Calculation Quality System",
  "$defs": {
    "RiskLevel": {
      "enum": ["high", "medium", "low"]
    },
    "RiskDomain": {
      "enum": [
        "tax_payroll",
        "pensions_benefits",
        "loans_financial",
        "utilities_meters",
        "exchange_rates",
        "health",
        "agriculture",
        "legal_regulatory",
        "general_utility"
      ]
    },
    "SourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registryId", "title", "url", "kind", "authorityStatus"],
      "properties": {
        "registryId": {"type": ["string", "null"]},
        "title": {"type": "string", "minLength": 2},
        "url": {"type": ["string", "null"], "format": "uri"},
        "kind": {"type": "string", "minLength": 2},
        "authorityStatus": {"enum": ["official-verified", "source-reviewed", "reviewed-dataset", "review-required"]}
      }
    },
    "EngineInventoryRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "artifactPath", "formulaFamily", "riskLevel", "riskDomain", "rationale", "formulaIds", "routeIds", "owner"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "artifactPath": {"type": "string", "minLength": 3},
        "formulaFamily": {"type": "string", "minLength": 2},
        "riskLevel": {"$ref": "#/$defs/RiskLevel"},
        "riskDomain": {"$ref": "#/$defs/RiskDomain"},
        "rationale": {"type": "string", "minLength": 20},
        "formulaIds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "routeIds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "owner": {"type": "string", "minLength": 2}
      }
    },
    "EngineInventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "schemaVersion", "generatedFrom", "engines"],
      "properties": {
        "$schema": {"type": "string"},
        "schemaVersion": {"const": 1},
        "generatedFrom": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "engines": {"type": "array", "items": {"$ref": "#/$defs/EngineInventoryRecord"}}
      }
    },
    "FormulaRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "formulaFamily", "formulaVersion", "artifactPath", "artifactDigest",
        "jurisdictions", "sourceJurisdictions", "applicablePopulation", "sources",
        "effectiveFrom", "effectiveTo", "effectiveDateStatus", "parameters", "rounding",
        "currency", "currencyAssumption", "currencyOverride", "units", "knownExclusions",
        "lastVerified", "verificationBasis", "owner", "disclaimer", "protectedDuplicates",
        "riskLevel", "riskDomain", "supportStatus"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 2},
        "formulaFamily": {"type": "string", "minLength": 2},
        "formulaVersion": {"type": "string", "pattern": "\\+sha256\\.[a-f0-9]{12}$"},
        "artifactPath": {"type": "string", "minLength": 3},
        "artifactDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "jurisdictions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "sourceJurisdictions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "applicablePopulation": {"type": "string", "minLength": 20},
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/SourceReference"}},
        "effectiveFrom": {"type": ["string", "null"], "format": "date"},
        "effectiveTo": {"type": ["string", "null"], "format": "date"},
        "effectiveDateStatus": {"enum": ["declared", "not-applicable", "review-required"]},
        "parameters": {"type": "object", "minProperties": 1},
        "rounding": {"type": "object", "minProperties": 1},
        "currency": {"type": ["string", "null"]},
        "currencyAssumption": {"type": "string", "minLength": 5},
        "currencyOverride": {"type": ["object", "null"]},
        "units": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "knownExclusions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "lastVerified": {"type": "string", "format": "date"},
        "verificationBasis": {"type": "string", "minLength": 5},
        "owner": {"type": "string", "minLength": 2},
        "disclaimer": {"type": "string", "minLength": 10},
        "protectedDuplicates": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "riskLevel": {"enum": ["high", "medium"]},
        "riskDomain": {"$ref": "#/$defs/RiskDomain"},
        "supportStatus": {"enum": ["registered", "legacy-protected", "review-required"]}
      }
    },
    "RouteMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolId", "formulaId", "routes", "sourceUrls"],
      "properties": {
        "toolId": {"type": "string"},
        "formulaId": {"type": "string"},
        "routes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "sourceUrls": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "format": "uri"}}
      }
    },
    "FormulaRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "schemaVersion", "formulas", "routeMappings"],
      "properties": {
        "$schema": {"type": "string"},
        "schemaVersion": {"const": 1},
        "formulas": {"type": "array", "items": {"$ref": "#/$defs/FormulaRecord"}},
        "routeMappings": {"type": "array", "items": {"$ref": "#/$defs/RouteMapping"}}
      }
    },
    "GoldenFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "formulaId", "formulaVersion", "caseClasses", "operation", "input", "expected", "tolerance", "evidence", "changeNote"],
      "properties": {
        "id": {"type": "string"},
        "formulaId": {"type": "string"},
        "formulaVersion": {"type": "string"},
        "caseClasses": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "operation": {"enum": ["paye-calculate", "tax-input-rejection", "formula-resolve"]},
        "input": {"type": "object"},
        "expected": {"type": "object", "minProperties": 1},
        "tolerance": {"type": "number", "minimum": 0},
        "evidence": {"$ref": "#/$defs/SourceReference"},
        "changeNote": {"type": "string", "minLength": 5}
      }
    },
    "GoldenFixtureRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "schemaVersion", "fixtures"],
      "properties": {
        "$schema": {"type": "string"},
        "schemaVersion": {"const": 1},
        "fixtures": {"type": "array", "items": {"$ref": "#/$defs/GoldenFixture"}}
      }
    },
    "ExternalDataContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "storageKey", "staticFallbackPath", "sourceRegistryId", "schemaVersion", "requiredPaths", "retrievedAtPath", "sourcePath", "maxAgeHours", "lastKnownGoodStrategy", "incompatibleAction", "publicStaleLabel", "forbiddenStaleLabels"],
      "properties": {
        "id": {"type": "string"},
        "storageKey": {"type": "string"},
        "staticFallbackPath": {"type": ["string", "null"]},
        "sourceRegistryId": {"type": "string"},
        "schemaVersion": {"type": "integer", "minimum": 1},
        "requiredPaths": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "retrievedAtPath": {"type": "string"},
        "sourcePath": {"type": "string"},
        "maxAgeHours": {"type": "integer", "minimum": 1},
        "lastKnownGoodStrategy": {"enum": ["retain-existing", "static-fallback", "reject-unavailable"]},
        "incompatibleAction": {"const": "reject-before-write"},
        "publicStaleLabel": {"type": "string", "pattern": "([Ss]tale|[Ee]stimate)"},
        "forbiddenStaleLabels": {"type": "array", "contains": {"const": "live"}}
      }
    },
    "ExternalDataRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "schemaVersion", "datasets"],
      "properties": {
        "$schema": {"type": "string"},
        "schemaVersion": {"const": 1},
        "datasets": {"type": "array", "items": {"$ref": "#/$defs/ExternalDataContract"}}
      }
    },
    "FixtureDeltaRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "schemaVersion", "deltas"],
      "properties": {
        "$schema": {"type": "string"},
        "schemaVersion": {"const": 1},
        "deltas": {"type": "array", "items": {"type": "object"}}
      }
    }
  }
}
