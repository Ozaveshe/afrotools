  "equivalenceGroups": [
    {
      "id": "directory:all-tools",
      "routes": {
        "en": "/tools/",
        "fr": "/fr/all-tools/",
        "sw": "/sw/zana-zote/",
        "yo": "/yo/awon-ise/",
        "ha": "/ha/kayan-aiki/"
      },
      "xDefault": "/tools/"
    },
    {
      "id": "category:document-pdf",
      "routes": {
        "en": "/document-pdf/",
        "fr": "/fr/document-pdf/"
      },
      "xDefault": "/document-pdf/"
    },
    {
      "id": "legal:privacy",
      "routes": {
        "en": "/privacy/",
        "fr": "/fr/privacy/"
      },
      "xDefault": "/privacy/"
    }
  ],
  "localeHomes": {
    "en": "/",
    "fr": "/fr/",
    "sw": "/sw/",
    "yo": "/yo/",
    "ha": "/ha/"
  },
  "fallbackLabels": {
    "en": "English fallback",
    "fr": "Version française indisponible — English fallback",
    "sw": "Kiswahili hakipatikani — English fallback",
    "yo": "Èdè Yorùbá kò sí — English fallback",
    "ha": "Babu Hausa — English fallback"
  },
  "routeNormalization": {
    "lowercaseCanonical": true,
    "stripQueryFromCanonical": true,
    "stripFragmentFromCanonical": true,
    "directoryRoutesUseTrailingSlash": true,
    "flatHtmlRoutesDropExtension": true,
    "slashOwner": "netlify-pretty-urls"
  },
  "pageTypeRules": [
    { "id": "tool", "pattern": "^/(?:fr/|sw/|yo/|ha/)?tools/", "pageType": "tool" },
    { "id": "widget", "pattern": "^/(?:fr/)?widgets/", "pageType": "widget" },
    { "id": "article", "pattern": "^/(?:fr/|sw/|yo/|ha/)?blog/", "pageType": "article" },
    { "id": "auth", "pattern": "^/(?:fr/|sw/|yo/|ha/)?auth(?:/|$)", "pageType": "auth" },
    { "id": "legal", "pattern": "^/(?:fr/|sw/|yo/|ha/)?(?:privacy|terms)(?:/|$)", "pageType": "legal" },
    { "id": "api", "pattern": "^/(?:api|\\.netlify/functions)(?:/|$)", "pageType": "api" },
    { "id": "category", "pattern": "^/(?:categories|salary-tax|document-pdf|developer-tools|agriculture|education|health|legal|trade|telecom|energy|image-design|language|small-business|personal-finance|data-productivity)(?:/|$)", "pageType": "category" },
    { "id": "country", "pattern": "^/(?:fr/|sw/|yo/|ha/)?[a-z0-9-]+/(?:[a-z]{2}-(?:paye|vat)|calculateur-|kikokotoo-)", "pageType": "country-tool" },
    { "id": "default", "pattern": ".*", "pageType": "page" }
  ],
  "sitemapRules": {
    "en": "sitemap-misc.xml",
    "fr": "sitemap-fr.xml",
    "sw": "sitemap-sw.xml",
    "yo": "sitemap-yo.xml",
    "ha": "sitemap-ha.xml"
  },
