{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/schemas/source-registry.schema.json",
  "title": "AfroTools Source Registry",
  "type": "object",
  "required": ["schemaVersion", "sources"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "updatedAt": {
      "$ref": "#/$defs/DateOrNull"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DataSourceMeta"
      }
    }
  },
  "$defs": {
    "DataSourceMeta": {
      "title": "DataSourceMeta",
      "type": "object",
      "required": [
        "id",
        "sourceName",
        "sourceType",
        "countryCodes",
        "appliesTo",
        "lastCheckedAt",
        "lastReviewedAt",
        "freshnessStatus",
        "confidence",
        "notes",
        "displayDisclaimer"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 2
        },
        "sourceName": {
          "type": "string",
          "minLength": 2
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "official",
            "regulator",
            "central_bank",
            "university",
            "foundation",
            "reviewed_dataset",
            "third_party_snapshot",
            "user_input",
            "estimate"
          ]
        },
        "countryCodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "appliesTo": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "tax",
              "fuel",
              "fx",
              "import_duty",
              "scholarships",
              "education",
              "salary",
              "business",
              "energy",
              "country_profile",
              "documents",
              "other"
            ]
          }
        },
        "effectiveFrom": {
          "$ref": "#/$defs/DateOrNull"
        },
        "effectiveTo": {
          "$ref": "#/$defs/DateOrNull"
        },
        "lastCheckedAt": {
          "$ref": "#/$defs/DateOrNull"
        },
        "lastReviewedAt": {
          "$ref": "#/$defs/DateOrNull"
        },
        "freshnessStatus": {
          "type": "string",
          "enum": ["fresh", "acceptable", "stale", "unknown", "unavailable"]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "official_verified",
            "reviewed",
            "estimated",
            "low_confidence",
            "user_entered"
          ]
        },
        "reviewCadenceDays": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        },
        "displayDisclaimer": {
          "type": "string",
          "minLength": 8
        }
      }
    },
    "DateOrNull": {
      "type": ["string", "null"],
      "format": "date"
    }
  }
}
