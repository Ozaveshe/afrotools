{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/schemas/ai-tool-context.schema.json",
  "title": "AfroTools AI per-tool context",
  "type": "object",
  "required": [
    "schemaVersion",
    "toolKey",
    "legacyTextSha256",
    "status",
    "staticText"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "toolKey": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "legacyTextSha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "status": {
      "enum": [
        "source-coupled",
        "unverified-static"
      ]
    },
    "staticText": {
      "type": "string"
    },
    "sourceBindings": {
      "type": "array",
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind"
        ],
        "properties": {
          "kind": {
            "enum": [
              "paye-engine",
              "vat-formula",
              "fuel-snapshot",
              "remittance-snapshot",
              "policy-rate-snapshot"
            ]
          },
          "countryCode": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "formulaId": {
            "type": "string"
          },
          "dataset": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "unverifiedStaticBlocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "status",
          "text"
        ],
        "properties": {
          "status": {
            "const": "unverified-static"
          },
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
