{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afrotools.com/schemas/tool-verification.schema.json",
  "title": "AfroTools Tool Verification",
  "type": "object",
  "required": ["version", "generated_at", "tools"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "format": "date" },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "tool_id",
          "jurisdiction",
          "routes",
          "source_urls",
          "source_titles",
          "last_verified",
          "verified_by",
          "risk_level",
          "disclaimer_type",
          "methodology_markdown",
          "known_limitations",
          "change_history",
          "test_cases"
        ],
        "properties": {
          "tool_id": { "type": "string", "minLength": 2 },
          "jurisdiction": { "type": "string", "minLength": 2 },
          "routes": {
            "type": "array",
            "items": { "type": "string", "pattern": "^/" },
            "minItems": 1,
            "uniqueItems": true
          },
          "source_urls": {
            "type": "array",
            "items": { "type": "string", "format": "uri" },
            "minItems": 1,
            "uniqueItems": true
          },
          "source_titles": {
            "type": "array",
            "items": { "type": "string", "minLength": 2 },
            "minItems": 1
          },
          "last_verified": { "type": "string", "format": "date" },
          "verified_by": { "type": "string", "minLength": 2 },
          "risk_level": { "enum": ["medium", "high", "critical"] },
          "disclaimer_type": { "enum": ["tax", "legal", "finance", "property", "health", "government"] },
          "law_or_version": { "type": "string" },
          "methodology_markdown": { "type": "string", "minLength": 20 },
          "known_limitations": {
            "type": "array",
            "items": { "type": "string", "minLength": 5 },
            "minItems": 1
          },
          "change_history": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["date", "note"],
              "properties": {
                "date": { "type": "string", "format": "date" },
                "note": { "type": "string", "minLength": 5 }
              }
            },
            "minItems": 1
          },
          "test_cases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["input", "expected_output", "why"],
              "properties": {
                "input": { "type": "string", "minLength": 2 },
                "expected_output": { "type": "string", "minLength": 2 },
                "why": { "type": "string", "minLength": 5 }
              }
            },
            "minItems": 1
          }
        }
      }
    }
  }
}
