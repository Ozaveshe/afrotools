# Copy to /opt/openclaw/.env or another private path and load with:
# docker compose --env-file /opt/openclaw/.env -f ops/openclaw/docker-compose.hostinger.yml up -d

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.1
OPENCLAW_ENV_FILE=/opt/openclaw/.env
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=Africa/Lagos
OPENCLAW_CONFIG_DIR=/opt/openclaw/config
AFROTOOLS_REPO_DIR=/opt/afrotools

# Leave blank unless you know you need it.
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
