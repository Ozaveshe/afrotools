        "CommandLine":  "\"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe\" -Command \"[Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\n$ErrorActionPreference = \u0027Stop\u0027\n$repo = (Get-Location).Path\n$reportDir = Join-Path $repo \u0027audit-results\u0027\n$processes = @(Get-CimInstance Win32_Process |\n  Where-Object {\n    $_.CommandLine -and ($_.CommandLine -match \u0027afrotools|cachebust|inject-internal-links|seo-daily-fix|build:deploy|build-dist|npm|node|git|codex|scholarship|study-context|context-bridge\u0027)\n  } |\n  Select-Object ProcessId, ParentProcessId, Name, CommandLine)\n$jobs = @(Get-Job)\n$tasks = @(Get-ScheduledTask |\n  Where-Object {\n    $_.TaskName -match \u0027afrotools|codex|npm|node|build|cachebust|seo|scholarship\u0027\n  } |\n  Select-Object TaskName, State, TaskPath)\n$repoPattern = [regex]::Escape($repo)\n$mutatorPattern = \u0027cachebust|inject-internal-links|seo-daily-fix|build:deploy|build-dist|npm\\s+run\\s+build|npm(?:\\.cmd)?\\s+run\\s+build|git(?:\\.exe)?\\s+.*\\b(add|restore|reset|clean|checkout|commit|merge|rebase|pull|push)\\b\u0027\n$repoProcesses = @($processes | Where-Object { $_.ProcessId -ne $PID -and $_.CommandLine -match $repoPattern })\n$repoMutators = @($processes | Where-Object { $_.ProcessId -ne $PID -and $_.CommandLine -match $repoPattern -and $_.CommandLine -match $mutatorPattern })\n$md = @()\n$md += \u0027# v8c Process Supervisor Check\u0027\n$md += \u0027\u0027\n$md += \\\"Checked: $(Get-Date -Format o)\\\"\n$md += \\\"Repo: $repo\\\"\n$md += \u0027\u0027\n$md += \\\"Matched process count: $($processes.Count)\\\"\n$md += \\\"Repo-local matched process count, excluding current shell: $($repoProcesses.Count)\\\"\n$md += \\\"Repo-local mutating process count, excluding current shell: $($repoMutators.Count)\\\"\n$md += \\\"PowerShell job count: $($jobs.Count)\\\"\n$md += \\\"Relevant scheduled task count: $($tasks.Count)\\\"\n$md += \u0027\u0027\n$md += \u0027## Matched Processes\u0027\nif ($processes.Count) { $md += ($processes | Format-List | Out-String).TrimEnd() } else { $md += \u0027None.\u0027 }\n$md += \u0027\u0027\n$md += \u0027## Repo-local Mutating Processes\u0027\nif ($repoMutators.Count) { $md += ($repoMutators | Format-List | Out-String).TrimEnd() } else { $md += \u0027None.\u0027 }\n$md += \u0027\u0027\n$md += \u0027## PowerShell Jobs\u0027\nif ($jobs.Count) { $md += ($jobs | Format-List | Out-String).TrimEnd() } else { $md += \u0027None.\u0027 }\n$md += \u0027\u0027\n$md += \u0027## Relevant Scheduled Tasks\u0027\nif ($tasks.Count) { $md += ($tasks | Format-List | Out-String).TrimEnd() } else { $md += \u0027None.\u0027 }\n$md += \u0027\u0027\n$md += \u0027## Decision\u0027\nif ($repoMutators.Count -gt 0) { $md += \u0027PROCESS SAFETY BLOCKER REMAINS: a repo-local mutating process is active.\u0027 } else { $md += \u0027No active repo-local mutating process or obvious scheduled supervisor was found.\u0027 }\n$md | Set-Content (Join-Path $reportDir \u0027v8c-process-supervisor-check.md\u0027) -Encoding UTF8\n$processes | ConvertTo-Json -Depth 4 | Set-Content (Join-Path $reportDir \u0027v8c-process-supervisor-check.json\u0027) -Encoding UTF8\n\\\"repoProcesses=$($repoProcesses.Count); repoMutators=$($repoMutators.Count); jobs=$($jobs.Count); scheduled=$($tasks.Count)\\\"\""
